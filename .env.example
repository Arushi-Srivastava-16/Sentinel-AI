# =============================================================================
# Sentinel AI — Environment Configuration Template
# Copy this file to .env and fill in real values.
# NEVER commit .env — it is listed in .gitignore.
# =============================================================================

# ---------------------------------------------------------------------------
# Gateway
# ---------------------------------------------------------------------------
# Root admin key — used to register agents and activate policies.
# Generate with: python3 -c "import secrets; print('snl_admin_' + secrets.token_hex(32))"
SENTINEL_ADMIN_KEY=snl_admin_REPLACE_ME

GATEWAY_ENV=development          # development | production
GATEWAY_LOG_LEVEL=INFO           # DEBUG | INFO | WARNING | ERROR

# ---------------------------------------------------------------------------
# JWT — RS256 key pair (generated by scripts/generate_certs.sh)
# ---------------------------------------------------------------------------
JWT_PRIVATE_KEY_PATH=./certs/private.pem
JWT_PUBLIC_KEY_PATH=./certs/public.pem

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=                  # leave blank for no auth (dev)

# ---------------------------------------------------------------------------
# Neo4j  (audit trail graph database)
# ---------------------------------------------------------------------------
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=REPLACE_ME
NEO4J_DATABASE=neo4j

# ---------------------------------------------------------------------------
# Ollama  (Judge Tier 1 — local LLM, optional)
# Run: ollama pull llama3.2:3b
# ---------------------------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_TIMEOUT_SECONDS=3

# ---------------------------------------------------------------------------
# OpenAI  (Judge Tier 3 — cloud fallback, required for cognitive path)
# ---------------------------------------------------------------------------
OPENAI_API_KEY=sk-proj-REPLACE_ME
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_SECONDS=20
OPENAI_BASE_URL=https://api.openai.com/v1

# ---------------------------------------------------------------------------
# Routing overrides  (useful for testing, leave false in production)
# ---------------------------------------------------------------------------
# Force every non-blocked request through the LLM judge (slow but thorough)
FORCE_COGNITIVE_PATH=false
# Skip Tier 1 (Ollama) and always use Tier 3 (OpenAI)
JUDGE_FORCE_TIER3_OPENAI=false

# ---------------------------------------------------------------------------
# Langfuse  (LLM observability — optional, leave blank to disable)
# ---------------------------------------------------------------------------
LANGFUSE_HOST=http://localhost:3001
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
